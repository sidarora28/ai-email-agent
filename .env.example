# Copy to .env and fill in. .env is gitignored.

# --- Gmail fetch (m1_voice/fetch_pairs.py, runs on your Mac) ---
GMAIL_CREDENTIALS_PATH=data/auth/credentials.json
GMAIL_TOKEN_PATH=data/auth/token.json
VOICE_PAIRS_LIMIT=200          # up to 200 substantive sent replies
MIN_REPLY_CHARS=200            # skip one-liners / trivial replies

# --- Embeddings (shared) ---
EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- Voice (M1) ---
VOICE_PAIRS=data/voice_pairs.jsonl
VOICE_PROFILE=data/voice_profile.md
VOICE_INDEX=data/voice_index.db
VOICE_PROFILE_MODEL=claude-opus-4-8   # Opus 4.8 writes the voice profile

# --- Knowledge (M1) ---
KNOWLEDGE_DIR=knowledge
KNOWLEDGE_INDEX=data/knowledge_index.db
