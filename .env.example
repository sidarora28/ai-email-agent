# Copy to .env and fill in. The .env file is gitignored.

# --- Gmail extraction (m1-voice/extract_emails.py) ---
# Path to the OAuth client secret you download from Google Cloud Console
# (APIs & Services -> Credentials -> OAuth client ID -> Desktop app).
GMAIL_CREDENTIALS_PATH=data/auth/credentials.json
# Where the saved OAuth token is cached after the first browser consent.
GMAIL_TOKEN_PATH=data/auth/token.json
# Which Gmail address to extract sent mail from.
GMAIL_USER=me
# How many sent emails to pull into the voice corpus.
EXTRACT_LIMIT=500

# --- Embeddings (m1-voice/build_embeddings.py, retrieve.py) ---
EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
CHROMA_PATH=data/embeddings.db
CHROMA_COLLECTION=voice
RETRIEVE_K=5

# --- Classification (m2-classifier/classify.py) ---
CONFIDENCE_THRESHOLD=0.7
