venv/
env/
.ipynb_checkpoints/

# --- OS ---
.DS_Store
Thumbs.db

# --- Streamlit ---
.streamlit/secrets.toml

# NOTE: data/embeddings.db is intentionally NOT ignored on the `failsafe`
# branch (it ships pre-populated). On `main` it starts empty and is rebuilt
# live, so the chroma sqlite file is ignored here to keep the repo clean.
data/embeddings.db/
*.sqlite3
