# --- Real inbox data (contains third-party PII — keep local, do NOT push) ---
# These stay on disk and persist across branch switches, so main + failsafe
# both see them locally. Regenerate with extract_emails.py / classify.py.
data/raw_emails.jsonl
data/inbound_emails.json
data/classified.json
data/classified.fallback.json
data/drafts.json
data/sample_inbound.txt

